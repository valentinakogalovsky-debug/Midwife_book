# Tally form ID from a URL like https://tally.so/r/abc123
NEXT_PUBLIC_TALLY_FORM_ID=

# Public contact links shown on the thank-you page and in the footer
# Example: https://wa.me/972XXXXXXXXX
NEXT_PUBLIC_WHATSAPP_LINK=

# Alternative to NEXT_PUBLIC_WHATSAPP_LINK: phone in international format
# Example: +972 54 123 4567
NEXT_PUBLIC_WHATSAPP_PHONE=

# Example: https://t.me/username
NEXT_PUBLIC_TELEGRAM_LINK=

# Alternative to NEXT_PUBLIC_TELEGRAM_LINK: username with or without @
# Example: michal_username
NEXT_PUBLIC_TELEGRAM_USERNAME=
